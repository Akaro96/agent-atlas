{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeGitInstructions": true,
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./private/**)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.claude.json)",
      "Read(~/.codex/auth.json)",
      "Read(~/.ssh/id_*)"
    ],
    "defaultMode": "default"
  },
  "language": "English",
  "effortLevel": "high",
  "voiceEnabled": false,
  "skipDangerousModePermissionPrompt": false
}
